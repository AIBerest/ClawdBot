# ClawdBot / OpenClaw isolated container runtime
#
# Copy to .env.container on the VPS and fill in the secrets/paths.

# Host bind for the published gateway port.
# Keep 127.0.0.1 unless you put a reverse proxy or SSH tunnel in front.
OPENCLAW_HOST_BIND=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# Runtime data on the VPS host.
OPENCLAW_CONFIG_DIR=/srv/clawdbot/runtime/openclaw-config
OPENCLAW_WORKSPACE_DIR=/srv/clawdbot/runtime/openclaw-workspace
SKILLS_REPO_DIR_HOST=/srv/clawdbot/runtime/skills-repo

# OpenClaw runtime env.
OPENCLAW_GATEWAY_TOKEN=change-me
PUSH_SKILLS_ALLOWED_SENDER_ID=
PUSH_SKILLS_SCRIPT=/opt/clawdbot/scripts/skills-git-push.sh
SKILLS_REPO_DIR=/srv/skills-repo
SKILLS_REPO_BRANCH=main
TZ=UTC

